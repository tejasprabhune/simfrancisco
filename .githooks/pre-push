#!/usr/bin/env bash
# Continuous-feedback gate (BRIEF §0): the model catches its own breakage from the check,
# not from a human. Enable with:  git config core.hooksPath .githooks
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

echo "[pre-push] cargo test ..."
cargo test --quiet

echo "[pre-push] cargo build --release --bin validate ..."
cargo build --release --bin validate --quiet

# Fast rubric smoke only when a key is available (skips silently in keyless CI).
if [ -f .env ] || [ -n "${MODEL_API_KEY:-}" ]; then
  echo "[pre-push] validate --smoke ..."
  if ! cargo run --release --bin validate -- --smoke --quiet; then
    echo "[pre-push] validate --smoke did not clear the gate — push aborted." >&2
    exit 1
  fi
else
  echo "[pre-push] no MODEL_API_KEY; skipping validate --smoke."
fi

echo "[pre-push] OK"
